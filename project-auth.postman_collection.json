{
  "info": {
    "_postman_id": "9c6ae2f5-b16c-4e35-8c57-faf5f0a4f5d1",
    "name": "Project Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('email')) pm.collectionVariables.set('email', 'patient@example.com');",
          "if (!pm.collectionVariables.get('password')) pm.collectionVariables.set('password', 'StrongPass123!');",
          "if (!pm.collectionVariables.get('newPassword')) pm.collectionVariables.set('newPassword', 'NewStrongPass123!');",
          "if (!pm.collectionVariables.get('updatedPassword')) pm.collectionVariables.set('updatedPassword', 'AnotherStrongPass123!');"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "email", "value": "patient@example.com" },
    { "key": "password", "value": "StrongPass123!" },
    { "key": "newPassword", "value": "NewStrongPass123!" },
    { "key": "updatedPassword", "value": "AnotherStrongPass123!" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "resetTokenId", "value": "" }
  ],
  "item": [
    {
      "name": "Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register status is 200/201/409', function () {",
              "  pm.expect([200, 201, 409]).to.include(pm.response.code);",
              "});",
              "let json = {};",
              "try { json = pm.response.json(); } catch (e) {}",
              "if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
              "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Login returns tokens', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Logout status is success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "logout"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Refresh status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Refresh returns tokens', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('accessToken', json.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.refreshToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "authorization-refresh", "value": "Bearer {{refreshToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/auth/refresh-token",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "refresh-token"]
        }
      }
    },
    {
      "name": "Forgot Password Link",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Forgot password status is success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "let json = {};",
              "try { json = pm.response.json(); } catch (e) {}",
              "if (json.tokenId) {",
              "  pm.collectionVariables.set('resetTokenId', json.tokenId);",
              "}",
              "pm.test('Reset token id available for next step', function () {",
              "  pm.expect(pm.collectionVariables.get('resetTokenId')).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/forgot-password-link",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "forgot-password-link"]
        }
      }
    },
    {
      "name": "Reset Password By Token Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Reset password status is success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "pm.collectionVariables.set('password', pm.collectionVariables.get('newPassword'));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/reset-password/{{resetTokenId}}",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "reset-password", "{{resetTokenId}}"]
        }
      }
    },
    {
      "name": "Update Password",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Update password status is success', function () {",
              "  pm.expect([200, 201]).to.include(pm.response.code);",
              "});",
              "pm.collectionVariables.set('password', pm.collectionVariables.get('updatedPassword'));"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"{{password}}\",\n  \"newPassword\": \"{{updatedPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/update-password",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "update-password"]
        }
      }
    }
  ]
}
