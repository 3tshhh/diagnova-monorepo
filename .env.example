REDIS_HOST=localhost
REDIS_PORT=6379

JWT_PREFIX=Bearer
JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
JWT_RESET_SECRET=replace_reset_secret

JWT_ACCESS_EXPIRES_IN=15m
